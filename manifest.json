{
  "manifest_version": 3,
  "name": "ContextClaw — Claude Context Preserver",
  "version": "1.1.0",
  "description": "Automatically save and restore Claude.ai conversation context across sessions.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://claude.ai/*",
    "https://generativelanguage.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://*.claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ContextClaw"
  },

  "web_accessible_resources": [
    {
      "resources": ["lib/compressor.js", "lib/storage.js", "lib/capsule.js"],
      "matches": ["https://claude.ai/*"]
    }
  ]
}