{
  "manifest_version": 3,
  "name": "Claude Context Preserver",
  "version": "1.1.0",
  "description": "Automatically save and restore Claude.ai conversation context across sessions.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://claude.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "http://www.w3.org/2000/svg"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://*.claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Claude Context Preserver",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon48.png",
      "32": "icons/icon48.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["lib/compressor.js", "lib/storage.js", "lib/capsule.js"],
      "matches": ["https://claude.ai/*"]
    }
  ]
}